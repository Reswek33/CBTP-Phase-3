generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- Enums ---

enum Role {
  ADMIN
  SUPERADMIN
  SUPPLIER
  BUYER
}

enum SupplierStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum BuyerStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum RfpPriority {
  NORMAL
  URGENT
}

enum RfpStatus {
  OPEN
  CLOSED
  AWARDED
  CANCELLED
}

enum BidStatus {
  PENDING_APPROVAL
  ACTIVE
  WINNING
  OUTBID
  WITHDRAWN
  AWARDED
}

enum Currency {
  USD
  EUR
  ETB
}

enum LogLevel {
  INFO
  WARN
  ERROR
  CRITICAL
}

// --- Models ---

model User {
  id           String   @id @default(uuid()) @db.Uuid
  firstName    String
  lastName     String
  username     String   @unique
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         Role     @default(BUYER)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // One-to-one profiles
  supplier Supplier?
  buyer    Buyer?

  // Relations
  activityLogs      ActivityLog[]
  systemLogs        SystemLog[]
  notifications     Notification[]
  sentMessages      Message[]          @relation("Sender")
  verifiedDocuments SupplierDocument[] @relation("Verifier")

  @@index([username, role])
  @@map("users")
  buyerDocuments BuyerDocument[] @relation("BuyerDocumentVerifier")
}

model Supplier {
  id                 String         @id @db.Uuid
  businessName       String         @map("business_name")
  phone              String?
  address            String?
  businessType       String?
  acceptLegalTerms   Boolean?       @default(false)
  taxId              String?        @unique @map("tax_id")
  registrationNumber String?        @unique @map("registration_number")
  yearsInBusiness    Int?           @map("years_in_business")
  categories         String[]
  bio                String?
  verificationStatus Boolean?       @default(false)
  status             SupplierStatus @default(PENDING)
  verifiedAt         DateTime?      @map("verified_at")
  rejectedReason     String?        @map("rejected_reason")
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")

  // Relations
  user          User               @relation(fields: [id], references: [id], onDelete: Cascade)
  documents     SupplierDocument[]
  bids          Bid[]
  conversations Conversation[]

  @@map("suppliers")
}

model Buyer {
  id                 String         @id @db.Uuid
  companyName        String         @map("company_name")
  companyType        String?        @map("company_type")
  taxId              String?        @map("tax_id")
  phone              String?
  industrySector     String?        @map("industry_sector")
  acceptLegalTerms   Boolean        @default(false)
  address            String?
  department         String?
  position           String?
  status             BuyerStatus    @default(PENDING)  // Changed from SupplierStatus
  verificationStatus Boolean?       @default(false)
  verifiedAt         DateTime?      @map("verified_at")
  rejectedReason     String?        @map("rejected_reason")
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")

  // Relations
  user          User               @relation(fields: [id], references: [id], onDelete: Cascade)
  rfps          Rfp[]
  conversations Conversation[]
  documents     BuyerDocument[]    

  @@map("buyers")
}

model BuyerDocument {
  id           String    @id @default(uuid()) @db.Uuid
  buyerId      String    @map("buyer_id") @db.Uuid
  documentType String    @map("document_type")
  fileName     String    @map("file_name")
  filePath     String    @map("file_path")
  uploadedAt   DateTime  @default(now()) @map("uploaded_at")
  verifiedBy   String?   @map("verified_by") @db.Uuid
  verifiedAt   DateTime? @map("verified_at")

  buyer    Buyer @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  verifier User? @relation("BuyerDocumentVerifier", fields: [verifiedBy], references: [id])

  @@index([buyerId])
  @@map("buyer_documents")
}

model Rfp {
  id          String      @id @default(uuid()) @db.Uuid
  buyerId     String      @map("buyer_id") @db.Uuid
  title       String
  description String?
  category    String
  budget      Decimal?    @db.Decimal(15, 2)
  currency    Currency    @default(ETB)
  deadline    DateTime    @db.Date
  priority    RfpPriority @default(NORMAL)
  status      RfpStatus   @default(OPEN)

  awardedBidId String? @map("awarded_bid_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  buyer         Buyer          @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  bids          Bid[]
  documents     RfpDocument[]
  conversations Conversation[]

  @@index([buyerId])
  @@index([status])
  @@map("rfps")
}

model Bid {
  id              String    @id @default(uuid()) @db.Uuid
  rfpId           String    @map("rfp_id") @db.Uuid
  supplierId      String    @map("supplier_id") @db.Uuid
  amount          Decimal?  @db.Decimal(15, 2)
  proposal        String?
  proposalPath    String?   @map("proposal_path")
  status          BidStatus @default(PENDING_APPROVAL)
  rejectionReason String?   @map("rejection_reason")
  createdAt       DateTime  @default(now()) @map("created_at")

  rfp      Rfp      @relation(fields: [rfpId], references: [id])
  supplier Supplier @relation(fields: [supplierId], references: [id])

  @@unique([rfpId, supplierId])
  @@map("bids")
}

model SupplierDocument {
  id           String    @id @default(uuid()) @db.Uuid
  supplierId   String    @map("supplier_id") @db.Uuid
  documentType String    @map("document_type")
  fileName     String    @map("file_name")
  filePath     String    @map("file_path")
  uploadedAt   DateTime  @default(now()) @map("uploaded_at")
  verifiedBy   String?   @map("verified_by") @db.Uuid
  verifiedAt   DateTime? @map("verified_at")

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  verifier User?    @relation("Verifier", fields: [verifiedBy], references: [id])

  @@index([supplierId])
  @@map("supplier_documents")
}

model RfpDocument {
  id        String   @id @default(uuid()) @db.Uuid
  rfpId     String   @map("rfp_id") @db.Uuid
  fileName  String   @map("file_name")
  filePath  String   @map("file_path")
  rfp       Rfp      @relation(fields: [rfpId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@map("rfp_documents")
}

model SystemLog {
  id      String   @id @default(uuid()) @db.Uuid
  level   LogLevel @default(INFO)
  message String
  context String?
  payload Json?
  userId  String?  @db.Uuid
  user    User?    @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@index([level, createdAt])
  @@map("system_logs")
}

// Minimal placeholder models for the remaining relations
model ActivityLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  action    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  content   String
  type      String   @default("GENERAL")
  link      String?
  isRead    Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model Conversation {
  id         String    @id @default(uuid()) @db.Uuid
  rfpId      String?   @db.Uuid
  buyerId    String    @db.Uuid
  supplierId String    @db.Uuid
  rfp        Rfp?      @relation(fields: [rfpId], references: [id])
  buyer      Buyer     @relation(fields: [buyerId], references: [id])
  supplier   Supplier  @relation(fields: [supplierId], references: [id])
  messages   Message[]
  createdAt  DateTime  @default(now())

  @@unique([rfpId, buyerId, supplierId])
}

model Message {
  id             String       @id @default(uuid()) @db.Uuid
  conversationId String       @db.Uuid
  senderId       String       @db.Uuid
  content        String
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  sender         User         @relation("Sender", fields: [senderId], references: [id])
}
