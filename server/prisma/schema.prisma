generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  SUPERADMIN
  SUPPLIER
  BUYER
}

enum BiddingType {
  PUBLIC
  CLOSED
}

enum BidRoomStatus {
  SCHEDULED    // Not yet started
  ACTIVE       // Currently accepting bids
  CLOSED       // Bidding ended
  CANCELLED    // Cancelled by buyer
  AWARDED      // Winner selected
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

enum ProposalDocumentStatus {
  REJECTED
  APPROVED
  PENDING
}

enum TokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum SupplierStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum BuyerStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum RfpPriority {
  NORMAL
  URGENT
}

enum RfpStatus {
  OPEN
  CLOSED
  AWARDED
  CANCELLED
}

enum BidStatus {
  PENDING_APPROVAL
  ACTIVE
  WINNING
  OUTBID
  WITHDRAWN
  AWARDED
  REJECTED
}

enum Currency {
  USD
  EUR
  ETB
}

enum LogLevel {
  INFO
  WARN
  ERROR
  CRITICAL
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  PENDING
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

// --- Models ---

model User {
  id           String   @id @default(uuid()) @db.Uuid
  firstName    String
  lastName     String
  username     String   @unique
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         Role     @default(BUYER)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // One-to-one profiles
  supplier Supplier?
  buyer    Buyer?

  // Relations
  activityLogs      ActivityLog[]
  systemLogs        SystemLog[]
  notifications     Notification[]
  sentMessages      Message[]          @relation("Sender")
  verifiedDocuments SupplierDocument[] @relation("Verifier")
  buyerDocuments    BuyerDocument[]    @relation("BuyerDocumentVerifier")
  
  // Bid Room Relations
  bidRoomsCreated   BidRoom[]          @relation("BuyerBidRooms")
  awardedBidRooms   BidRoom[]          @relation("AwardedBy")
  roomInvitations   BidRoomInvitation[] @relation("Inviter")
  bidActivities     BidActivityLog[]    @relation("Actor")
  
  // Subscription Relations
  subscriptions     Subscription[]
  transactions      PaymentTransaction[]

  @@index([username, role])
  @@map("users")
}

model Supplier {
  id                 String         @id @db.Uuid
  businessName       String         @map("business_name")
  phone              String?
  address            String?
  businessType       String?
  acceptLegalTerms   Boolean?       @default(false)
  taxId              String?        @unique @map("tax_id")
  registrationNumber String?        @unique @map("registration_number")
  yearsInBusiness    Int?           @map("years_in_business")
  categories         String[]
  bio                String?
  verificationStatus Boolean?       @default(false)
  status             SupplierStatus @default(PENDING)
  verifiedAt         DateTime?      @map("verified_at")
  rejectedReason     String?        @map("rejected_reason")
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")

  // Relations
  user          User               @relation(fields: [id], references: [id], onDelete: Cascade)
  documents     SupplierDocument[]
  bids          Bid[]
  conversations Conversation[]
  
  // Bid Room Relations
  roomInvitations BidRoomInvitation[]
  roomBids        RoomBid[]

  @@map("suppliers")
}

model Buyer {
  id                 String      @id @db.Uuid
  companyName        String      @map("company_name")
  companyType        String?     @map("company_type")
  taxId              String?     @map("tax_id")
  phone              String?
  industrySector     String?     @map("industry_sector")
  acceptLegalTerms   Boolean     @default(false)
  address            String?
  department         String?
  position           String?
  status             BuyerStatus @default(PENDING)
  verificationStatus Boolean?    @default(false)
  verifiedAt         DateTime?   @map("verified_at")
  rejectedReason     String?     @map("rejected_reason")
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")

  // Relations
  user          User            @relation(fields: [id], references: [id], onDelete: Cascade)
  rfps          Rfp[]
  conversations Conversation[]
  documents     BuyerDocument[]

  @@map("buyers")
}

model BuyerDocument {
  id           String    @id @default(uuid()) @db.Uuid
  buyerId      String    @map("buyer_id") @db.Uuid
  documentType String    @map("document_type")
  fileName     String    @map("file_name")
  filePath     String    @map("file_path")
  uploadedAt   DateTime  @default(now()) @map("uploaded_at")
  verifiedBy   String?   @map("verified_by") @db.Uuid
  verifiedAt   DateTime? @map("verified_at")

  buyer    Buyer @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  verifier User? @relation("BuyerDocumentVerifier", fields: [verifiedBy], references: [id])

  @@index([buyerId])
  @@map("buyer_documents")
}

model Rfp {
  id          String      @id @default(uuid()) @db.Uuid
  buyerId     String      @map("buyer_id") @db.Uuid
  title       String
  description String?
  category    String
  budget      Decimal?    @db.Decimal(15, 2)
  currency    Currency    @default(ETB)
  deadline    DateTime    @db.Date
  priority    RfpPriority @default(NORMAL)
  status      RfpStatus   @default(OPEN)

  awardedBidId String? @map("awarded_bid_id") @db.Uuid

  requiresApproval Boolean          @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  buyer         Buyer          @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  bids          Bid[]
  documents     RfpDocument[]
  conversations Conversation[]
  bidRooms      BidRoom[]

  @@index([buyerId])
  @@index([status])
  @@map("rfps")
}

model Bid {
  id              String             @id @default(uuid()) @db.Uuid
  rfpId           String             @map("rfp_id") @db.Uuid
  supplierId      String             @map("supplier_id") @db.Uuid
  amount          Decimal?           @db.Decimal(15, 2)
  proposal        String?
  proposalPath    String?            @map("proposal_path")
  status          BidStatus          @default(PENDING_APPROVAL)
  rejectionReason String?            @map("rejection_reason")
  createdAt       DateTime           @default(now()) @map("created_at")
  
  isEligibleForBidRoom Boolean        @default(false) @map("is_eligible_for_bid_room")
  invitedToBidRoom    Boolean         @default(false) @map("invited_to_bid_room")
  
  rfp       Rfp                @relation(fields: [rfpId], references: [id])
  supplier  Supplier           @relation(fields: [supplierId], references: [id])
  documents ProposalDocument[]

  @@unique([rfpId, supplierId])
  @@map("bids")
}

model ProposalDocument {
  id         String                 @id @default(uuid()) @db.Uuid
  bidId      String                 @map("bid_id") @db.Uuid
  title      String?
  fileName   String                 @map("file_name")
  filePath   String                 @map("file_path")
  status     ProposalDocumentStatus @default(PENDING)
  uploadedAt DateTime               @default(now()) @map("uploaded_at")

  bid Bid @relation(fields: [bidId], references: [id], onDelete: Cascade)

  @@index([bidId])
  @@map("proposal_documents")
}

model SupplierDocument {
  id           String    @id @default(uuid()) @db.Uuid
  supplierId   String    @map("supplier_id") @db.Uuid
  documentType String    @map("document_type")
  fileName     String    @map("file_name")
  filePath     String    @map("file_path")
  uploadedAt   DateTime  @default(now()) @map("uploaded_at")
  verifiedBy   String?   @map("verified_by") @db.Uuid
  verifiedAt   DateTime? @map("verified_at")

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  verifier User?    @relation("Verifier", fields: [verifiedBy], references: [id])

  @@index([supplierId])
  @@map("supplier_documents")
}

model RfpDocument {
  id        String   @id @default(uuid()) @db.Uuid
  rfpId     String   @map("rfp_id") @db.Uuid
  fileName  String   @map("file_name")
  filePath  String   @map("file_path")
  rfp       Rfp      @relation(fields: [rfpId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@map("rfp_documents")
}

model SystemLog {
  id      String   @id @default(uuid()) @db.Uuid
  level   LogLevel @default(INFO)
  message String
  context String?
  payload Json?
  userId  String?  @db.Uuid
  user    User?    @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@index([level, createdAt])
  @@map("system_logs")
}

model ActivityLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  action    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  content   String
  type      String   @default("GENERAL")
  link      String?
  isRead    Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model Conversation {
  id         String    @id @default(uuid()) @db.Uuid
  rfpId      String?   @db.Uuid
  buyerId    String    @db.Uuid
  supplierId String    @db.Uuid
  rfp        Rfp?      @relation(fields: [rfpId], references: [id])
  buyer      Buyer     @relation(fields: [buyerId], references: [id])
  supplier   Supplier  @relation(fields: [supplierId], references: [id])
  messages   Message[]
  createdAt  DateTime  @default(now())

  @@unique([rfpId, buyerId, supplierId])
}

model Message {
  id             String       @id @default(uuid()) @db.Uuid
  conversationId String       @db.Uuid
  senderId       String       @db.Uuid
  content        String
  isRead         Boolean      @default(false) @map("is_read")
  readAt         DateTime?    @map("read_at")
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  sender         User         @relation("Sender", fields: [senderId], references: [id])
}

model VerificationToken {
  id      String    @id @default(uuid())
  email   String
  token   String
  expires DateTime
  type    TokenType

  @@unique([email, token])
}

model BidRoom {
  id            String         @id @default(uuid()) @db.Uuid
  rfpId         String         @map("rfp_id") @db.Uuid
  buyerId       String         @map("buyer_id") @db.Uuid
  biddingType   BiddingType    @default(PUBLIC)
  status        BidRoomStatus  @default(SCHEDULED)
  
  startTime     DateTime       @map("start_time")
  endTime       DateTime       @map("end_time")
  duration      Int?           
  
  winningBidId  String?        @map("winning_bid_id") @db.Uuid
  awardedAt     DateTime?      @map("awarded_at")
  awardedBy     String?        @map("awarded_by") @db.Uuid
  
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  
  rfp           Rfp            @relation(fields: [rfpId], references: [id], onDelete: Cascade)
  buyer         User           @relation("BuyerBidRooms", fields: [buyerId], references: [id])
  awardedByUser User?          @relation("AwardedBy", fields: [awardedBy], references: [id])
  
  invitations   BidRoomInvitation[]
  bids          RoomBid[]
  activityLogs  BidActivityLog[]
  
  @@index([rfpId])
  @@index([status])
  @@index([startTime, endTime])
  @@map("bid_rooms")
}

model BidRoomInvitation {
  id             String            @id @default(uuid()) @db.Uuid
  bidRoomId      String            @map("bid_room_id") @db.Uuid
  supplierId     String            @map("supplier_id") @db.Uuid
  invitedBy      String            @map("invited_by") @db.Uuid
  status         InvitationStatus  @default(PENDING)
  invitedAt      DateTime          @default(now()) @map("invited_at")
  respondedAt    DateTime?         @map("responded_at")
  expiresAt      DateTime?         @map("expires_at")
  
  bidRoom        BidRoom           @relation(fields: [bidRoomId], references: [id], onDelete: Cascade)
  supplier       Supplier          @relation(fields: [supplierId], references: [id])
  inviter        User              @relation("Inviter", fields: [invitedBy], references: [id])
  
  @@unique([bidRoomId, supplierId])
  @@index([bidRoomId, status])
  @@map("bid_room_invitations")
}

model RoomBid {
  id             String         @id @default(uuid()) @db.Uuid
  bidRoomId      String         @map("bid_room_id") @db.Uuid
  supplierId     String         @map("supplier_id") @db.Uuid
  amount         Decimal        @db.Decimal(15, 2)
  currency       Currency       @default(ETB)
  
  encryptedAmount String?       @map("encrypted_amount")
  isBlindBid     Boolean        @default(false)
  
  bidOrder       Int?           @map("bid_order")
  previousAmount Decimal?       @map("previous_amount")   @db.Decimal(15, 2)
  
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  
  bidRoom        BidRoom        @relation(fields: [bidRoomId], references: [id], onDelete: Cascade)
  supplier       Supplier       @relation(fields: [supplierId], references: [id])
  
  ipAddress      String?        @map("ip_address")
  userAgent      String?        @map("user_agent")
  
  @@unique([bidRoomId, supplierId])
  @@index([bidRoomId, amount])
  @@map("room_bids")
}

model BidActivityLog {
  id             String         @id @default(uuid()) @db.Uuid
  bidRoomId      String         @map("bid_room_id") @db.Uuid
  actorId        String         @map("actor_id") @db.Uuid
  action         String         
  details        Json?          
  oldAmount      Decimal?       @map("old_amount") @db.Decimal(15, 2)
  newAmount      Decimal?       @map("new_amount") @db.Decimal(15, 2)
  createdAt      DateTime       @default(now()) @map("created_at")
  
  bidRoom        BidRoom        @relation(fields: [bidRoomId], references: [id], onDelete: Cascade)
  actor          User           @relation("Actor", fields: [actorId], references: [id])
  
  @@index([bidRoomId, createdAt])
  @@map("bid_activity_logs")
}
model Plan {
  id           String   @id @default(uuid()) @db.Uuid
  name         String   @unique
  description  String?
  price        Decimal  @db.Decimal(15, 2)
  currency     Currency @default(ETB)
  durationDays Int      @map("duration_days")
  features     Json?
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  subscriptions Subscription[]
  transactions  PaymentTransaction[]

  @@map("plans")
}

model Subscription {
  id             String             @id @default(uuid()) @db.Uuid
  userId         String             @db.Uuid @map("user_id")
  planId         String             @db.Uuid @map("plan_id")
  status         SubscriptionStatus @default(PENDING)
  startDate      DateTime?          @map("start_date")
  endDate        DateTime?          @map("end_date")
  txRef          String?            @unique @map("tx_ref")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan @relation(fields: [planId], references: [id])

  @@map("subscriptions")
}

model PaymentTransaction {
  id        String            @id @default(uuid()) @db.Uuid
  userId    String            @db.Uuid @map("user_id")
  planId    String            @db.Uuid @map("plan_id")
  amount    Decimal           @db.Decimal(15, 2)
  currency  Currency          @default(ETB)
  txRef     String            @unique @map("tx_ref")
  status    TransactionStatus @default(PENDING)
  payload   Json?
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])
  plan Plan @relation(fields: [planId], references: [id])

  @@map("payment_transactions")
}
